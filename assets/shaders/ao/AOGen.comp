#version 450

#define KERNEL_NAIVE 0
#define KERNEL_ALCHEMY 1

#define USED_KERNEL 1

layout (local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout (set = 0, binding = 0, Rgba8) uniform writeonly image2D iAOResult;

layout(set = 0, binding = 1) uniform sampler2D sZBuffer;

layout(push_constant) uniform PushConstants {
    vec4 TopLeft;
    vec4 TopRight;
    vec4 BottomLeft;
    vec4 BottomRight;
} uPushConstants;

vec2 GetTextureCoords(ivec2 texelCoords)
{
    return (vec2(texelCoords) + 0.5) / vec2(imageSize(iAOResult));
}

float SampleZ(vec2 uv, float lod)
{
    return textureLod(sZBuffer, uv, lod).r;
}

vec3 ReconstructPosition(vec2 uv, float z)
{
    vec3 top = mix(uPushConstants.TopLeft.xyz,    uPushConstants.TopRight.xyz,    uv.x);
    vec3 bot = mix(uPushConstants.BottomLeft.xyz, uPushConstants.BottomRight.xyz, uv.x);
    vec3 dir = mix(top, bot, uv.y);

    return z * dir;
}

float DepthAtSample(vec3 samplePos, float lod)
{
    // 2D coords of view-space sample point
    // projected on the z=1 plane:
    vec2 viewCoord = samplePos.xy / samplePos.z;
       
    // Displacement form the top left cornet:
    vec2 viewDisp = viewCoord - uPushConstants.TopLeft.xy;
    
    // Retrieve interpolation coeefictients (uv for depth)
    // by computing normalized dot products:
    const vec2 dx = uPushConstants.TopRight.xy - uPushConstants.TopLeft.xy;
    const vec2 dy = uPushConstants.BottomLeft.xy - uPushConstants.TopLeft.xy;
    
    vec2 uv = vec2(
        dot(viewDisp, dx) / dot(dx, dx), 
        dot(viewDisp, dy) / dot(dy, dy)
    );
    
    // Sample depth:
    return SampleZ(uv, lod);
}

struct Basis{
    vec3 T;
    vec3 B;
    vec3 N;
};

Basis GetTangentBasis(vec2 uv, vec3 pos0, float depth0)
{
    //Imporved normal reconstruction from depth, based on:
    //https://wickedengine.net/2019/09/improved-normal-reconstruction-from-depth/
    
    //TODO: This can be optimized with shared memory as in original blog.
    //And further:
    //https://atyuwen.github.io/posts/normal-reconstruction/

    vec2 texelSize = 1.0 / vec2(imageSize(iAOResult));

    vec2 uvLeft   = uv - texelSize * vec2(1,0);
    vec2 uvRight  = uv + texelSize * vec2(1,0);
    vec2 uvBottom = uv - texelSize * vec2(0,1);
    vec2 uvTop    = uv + texelSize * vec2(0,1);

    float depthLeft   = SampleZ(uvLeft, 0.0);
    float depthRight  = SampleZ(uvRight, 0.0);
    float depthBottom = SampleZ(uvBottom, 0.0);
    float depthTop    = SampleZ(uvTop, 0.0);

    bool pickRight = abs(depthRight - depth0) < abs(depthLeft   - depth0);
    bool pickTop   = abs(depthTop   - depth0) < abs(depthBottom - depth0);

    bool swapOrientation = pickRight ^^ pickTop;

    vec3 posHorizontal = pickRight 
                       ? ReconstructPosition(uvRight, depthRight) 
                       : ReconstructPosition(uvLeft, depthLeft);

    vec3 posVertical = pickTop
                     ? ReconstructPosition(uvTop, depthTop) 
                     : ReconstructPosition(uvBottom, depthBottom);

    vec3 T, B;
    
    if (swapOrientation)
    {
        T = normalize(posVertical - pos0);
        B = normalize(posHorizontal - pos0);
    }
    else {
        T = normalize(posHorizontal - pos0);
        B = normalize(posVertical - pos0);
    }
    //TODO: T and B should probably be orthonormalzied with Gram-Schmidt:

    vec3 N = normalize(cross(T, B));

    return Basis(T, B, N);
}


//TODO: sample generation should be optimized
