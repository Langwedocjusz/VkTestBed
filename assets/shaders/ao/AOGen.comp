//High quality hash functions based on:
//https://www.shadertoy.com/view/ttc3zr

uint murmurHash12(uvec2 src) {
    const uint M = 0x5bd1e995u;
    uint h = 1190494759u;
    src *= M; src ^= src>>24u; src *= M;
    h *= M; h ^= src.x; h *= M; h ^= src.y;
    h ^= h>>13u; h *= M; h ^= h>>15u;
    return h;
}

// 1 output, 2 inputs
float hash12(uvec2 src) {
    uint h = murmurHash12(src);
    return uintBitsToFloat(h & 0x007fffffu | 0x3f800000u) - 1.0;
}

uint murmurHash13(uvec3 src) {
    const uint M = 0x5bd1e995u;
    uint h = 1190494759u;
    src *= M; src ^= src>>24u; src *= M;
    h *= M; h ^= src.x; h *= M; h ^= src.y; h *= M; h ^= src.z;
    h ^= h>>13u; h *= M; h ^= h>>15u;
    return h;
}

float hash13(inout uvec3 src) {
    uint h = murmurHash13(src);
    src.z += 1;

    return uintBitsToFloat(h & 0x007fffffu | 0x3f800000u) - 1.0;
}


vec3 GenerateSampleOffset(inout uvec3 state)
{
    vec3 offset = vec3(
        2.0 * hash13(state) - 1.0,
        2.0 * hash13(state) - 1.0,
        hash13(state)
    );

    offset = normalize(offset);
    offset *= hash13(state);

    return offset;
}



float KernelSSAONaive(vec3 pos, Basis TBN, inout uvec3 rngState)
{
    const int SSAO_SAMPLE_COUNT = 48;
    const float SSAO_RADIUS = 0.2;
    const float SSAO_HEURISTIC_THICKNESS = 1.0;

    float acc = 0.0;
    
    for (int i=0; i<SSAO_SAMPLE_COUNT; i++)
    {
        vec3 offsetTan = SSAO_RADIUS * GenerateSampleOffset(rngState);
        vec3 offset = TBN.T * offsetTan.x + TBN.B * offsetTan.y + TBN.N * offsetTan.z;
    
        vec3 samplePos = pos + offset;

        // Using higher lod of the Z-buffer for further away samples
        // to prevent cache-trashing:
        // TODO: fNear should be fetched from camera.    
        // TODO: Lod calculation should be performed in
        // texel-units, where the magic value "13.0"
        // would be translated to something more meaningful.
        const float F_NEAR = 0.01;
        float screenOffset = (F_NEAR/pos.z) * length(offsetTan);
        float lod = log2(screenOffset) + 13.0; 

        float bufferDepth = DepthAtSample(samplePos, lod);
    
        //TODO: continuous attenuation function would remove cutoff artefacts.
        if (abs(pos.z - bufferDepth) < SSAO_HEURISTIC_THICKNESS)
        {
            float occluded = float(bufferDepth <= samplePos.z);
            acc += occluded;
        }
    }
    
    acc /= float(SSAO_SAMPLE_COUNT);

    return 1.0 - acc;
}

vec2 VogelDisk(int idx, int num_samples, float rotation)
{
    const float G_A = 2.399963;
    const float HPI = 1.570796;

    vec2 dir = cos(idx * G_A + rotation + vec2(0, HPI));
    float r = sqrt(float(idx)/float(num_samples));

    return r * dir;
}

// Sampling stragety based on Alchemy Ambient 
// Obscurance and Volumetric Obscurance.
// Visibility is treated differently to Alchemy paper.
float KernelSSAOAlchemy(vec3 pos, Basis TBN, float hash)
{
    const int SSAO_SAMPLE_COUNT = 48;
    const float SSAO_RADIUS = 0.1;
    const float SSAO_HEURISTIC_THICKNESS = 0.5;

    float volTotal = 0.0;
    float volOccupied = 0.0;

    for (int i=1; i<SSAO_SAMPLE_COUNT; i++)
    {
        vec2 offset2 = SSAO_RADIUS * VogelDisk(i, SSAO_SAMPLE_COUNT, hash);
        vec3 offset = vec3(offset2, 0.0);

        vec3 samplePos = pos + offset;

        // Position snapped to the closer hemisphere:
        float halfHeight = sqrt(SSAO_RADIUS * SSAO_RADIUS - dot(offset2, offset2));
        float topZ = samplePos.z - halfHeight;

        // Position snapped to the tangent plane (lowest visible):
        mat2 invMat;
        {
            // NOTE: Just using inverse produces artefacts when
            // the determinant has wrong sign (which sign
            // is wrong depends on Z buffer orientation).
            const float a = TBN.T.x, b = TBN.T.y;
            const float c = TBN.B.x, d = TBN.B.y;

            const float det = -abs(a*d - b*c);
            invMat = mat2(d, -b, -c, a) / det;
        }
        
        vec2 coords = invMat * offset2;
        vec3 snappedOffset = coords.x * TBN.T + coords.y * TBN.B;
        
        float bottomZ = pos.z + snappedOffset.z;

        // Discard samples where ray passes beneath tangent plane:
        if (bottomZ <= topZ)
            continue;

        // If tangent plane is beneath lower hemisphere
        // snap to that instead:
        bottomZ = min(bottomZ, samplePos.z + halfHeight);

        // Position snapped to the 'ground' (Z-buffer):

        float ground_z = DepthAtSample(samplePos, 1.0);

        if (abs(pos.z - ground_z) > SSAO_HEURISTIC_THICKNESS)
            ground_z = bottomZ;
        else
            ground_z = clamp(ground_z, topZ, bottomZ);

        // Integrate total volume and the occupied part:
        float maxHeight = topZ - bottomZ;
        float occupiedHeight = ground_z - bottomZ;

        volOccupied += occupiedHeight;
        volTotal += maxHeight;
    }

    float occupiedRatio = volOccupied/volTotal;

    return 1.0 - occupiedRatio;
}

void main()
{
    ivec2 texelCoords = ivec2(gl_GlobalInvocationID.xy);

    vec2 uv = GetTextureCoords(texelCoords);
    float depth = SampleZ(uv, 0.0);

    vec3 pos = ReconstructPosition(uv, depth);
    Basis TBN = GetTangentBasis(uv, pos, depth);

    float ao;

    #if(USED_KERNEL == KERNEL_NAIVE)
    uvec3 rngState = uvec3(texelCoords.x, texelCoords.y, 0);
    ao = KernelSSAONaive(pos, TBN, rngState);
    
    #elif(USED_KERNEL == KERNEL_ALCHEMY)
    float hash = 2.0 * 3.1415 * hash12(texelCoords);
    ao = KernelSSAOAlchemy(pos, TBN, hash);

    #endif

    vec4 res = vec4(0.5*TBN.N+0.5, ao);

    imageStore(iAOResult, texelCoords, res);
}

